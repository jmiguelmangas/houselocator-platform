# Copiar a .env y rellenar. .env nunca se commitea (ver .gitignore).

# --- Postgres ---
POSTGRES_USER=houselocator
POSTGRES_PASSWORD=changeme
POSTGRES_DB=houselocator

# --- Telegram bot (houselocator-bot) ---
# Token del bot creado con @BotFather
TELEGRAM_BOT_TOKEN=
# user_id numérico de Telegram del único usuario autorizado (el bot ignora al resto)
TELEGRAM_ALLOWED_USER_ID=
# chat_id donde se mandan alertas de salud del scraper (puede ser el mismo user_id)
TELEGRAM_ADMIN_CHAT_ID=

# --- Ingest (houselocator-ingest) ---
# Idealista está bloqueado por DataDome para scraping directo (curl_cffi y
# FlareSolverr no bastan, ver docs/HLD.md §3) — se usa su API oficial.
# Solicitar en https://developers.idealista.com/access-request (gratuita,
# ~100 peticiones/mes). Mientras no estén rellenas, ese portal simplemente
# queda en estado "blocked" en scrape_runs sin afectar a Fotocasa.
IDEALISTA_API_KEY=
IDEALISTA_API_SECRET=
